# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://founder_intel:password@localhost:5432/founder_intel?schema=public"

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── API ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1

# ─── YC Adapter ─────────────────────────────────────────────────────────────
# YC uses Algolia under the hood; these are the public read-only search credentials
# embedded in their frontend bundle. Check robots.txt before enabling.
YC_ALGOLIA_APP_ID=45BWZJ1SGC
YC_ALGOLIA_SEARCH_KEY=
YC_RATE_LIMIT_MS=500
YC_ENABLED=true

# ─── FoundersList Adapter ────────────────────────────────────────────────────
FOUNDERS_LIST_RATE_LIMIT_MS=1000
FOUNDERS_LIST_ENABLED=true

# ─── Secondary Sources (scaffolded, disabled by default) ────────────────────
PRODUCT_HUNT_API_KEY=
PRODUCT_HUNT_ENABLED=false

BETALIST_ENABLED=false

COFOUNDERS_LAB_ENABLED=false

# ─── Matching ────────────────────────────────────────────────────────────────
RESOLVER_VERSION=1.0.0
# Minimum confidence to auto-merge (below → REVIEW)
MATCH_AUTO_THRESHOLD=0.85

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info
