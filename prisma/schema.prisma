  match_score          Int @default(0)
  reputation_score     Int @default(0)
  founder_sentiment    Int @default(0)
  industry_reputation  Int @default(0)
  responsiveness_score Int @default(0)
  founder_satisfaction Int @default(0)
  value_add_ability    Int @default(0)
  network_strength     Int @default(0)
  active_deployment    Int @default(0)

  explanation   String?  @db.Text
  model_version String?
