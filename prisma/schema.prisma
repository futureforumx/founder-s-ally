// =============================================================================
// VCFirm
// =============================================================================

model VCFirm {
  id String @id @default(cuid())

  firm_name      String
  legal_name     String?
  slug           String  @unique
  logo_url       String?
  elevator_pitch String?
  description    String? @db.Text

  website_url String?
  email       String?
  phone       String?
  address     String?

  hq_city    String?
  hq_state   String?
  hq_country String?
  locations  Json?

  x_url         String?
  linkedin_url  String?
  substack_url  String?
  medium_url    String?
  beehiiv_url   String?
  instagram_url String?
  facebook_url  String?
  youtube_url   String?
  tiktok_url    String?

  crunchbase_url    String?
  cb_insights_url   String?
  signal_nfx_url    String?
  vcsheet_url       String?
  vcprodatabase_url String?
  venturexpert_url  String?
  angellist_url     String?
  openvc_url        String?
  trustfinta_url    String?

  total_headcount       Int?
  total_investors       Int?
  total_partners        Int?
  general_partner_count Int?
  partner_names         String[] @default([])
  general_partner_names String[] @default([])

  firm_type             FirmType @default(INSTITUTIONAL)
  /// Derived from largest fund vehicle (max of AUM / size per fund); optional manual override path via workers.
  aum_band              AumBand?
  founded_year          Int?
  status                String?
  verification_status   String?
  data_confidence_score Int?

  reputation_score     Int?
  founder_sentiment    Int?
  industry_reputation  Int?
  responsiveness_score Int?
  value_add_score      Int?
  network_strength     Int?
  match_score          Int?

  /// Gemini text-embedding-004 (768-dim) of elevator_pitch / thesis.
  /// Written by the AI enrichment worker; use raw SQL or pg client for vector ops.
  thesis_embedding Unsupported("vector(768)")?

  /// 1 = mega-fund (slow decay), 2 = mid-size, 3 = micro-fund (fast decay)
  volatility_score         Int      @default(1)
  last_verified_at         DateTime @default(now()) @db.Timestamptz(6)
  next_update_scheduled_at DateTime @default(dbgenerated("(now() + '30 days'::interval)")) @db.Timestamptz(6)

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  funds              VCFund[]
  people             VCPerson[]
  signals            VCSignal[]
  recent_investments VCInvestment[]
  source_links       VCSourceLink[]
  score_snapshots    VCScoreSnapshot[]
  ratings            VCRating[]
  aliases            VCFirmAlias[]
  reg_d_filings      RegDFiling[]

  @@index([firm_name])
  @@index([firm_type])
  @@index([aum_band])
  @@index([hq_country, hq_state, hq_city])
  @@index([match_score])
  @@index([reputation_score])
  @@index([founder_sentiment])
  @@index([industry_reputation])
  @@index([next_update_scheduled_at])
  @@index([deleted_at])
  @@map("vc_firms")
}

/// Maps normalized alternate keys (domains, slugs, legal names, vendor IDs) to the canonical `vc_firms` row.
/// Store `alias_value` in a consistent normalized form (e.g. lowercase host without `www.`).
model VCFirmAlias {
  id      String @id @default(cuid())
  firm_id String
  firm    VCFirm @relation(fields: [firm_id], references: [id], onDelete: Cascade)

  alias_type  VCFirmAliasType
  alias_value String          @db.Text

  /// Provenance: importer name, "merge", "admin", etc.
  source     String?
  notes      String? @db.Text
  /// Optional match strength for fuzzy / heuristic links (0–1).
  confidence Float?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([alias_type, alias_value])
  @@index([firm_id])
  @@index([alias_value])
  @@map("vc_firm_aliases")
}

/// Parsed SEC Form D filing (Regulation D). VC_FUND rows link to vc_firms + vc_funds; STARTUP rows stand in for issuer "company" until claimed in product.
model RegDFiling {
  id                 String         @id @default(cuid())
  kind               RegDFilingKind
  entity_name        String
  industry_group     String?        @db.Text
  total_offering_raw String?        @map("total_offering_raw") @db.Text
  amount_raised_usd  Float?
  filing_date        DateTime?
  /// primary_doc.xml URL (unique ingestion key)
  source_url         String         @unique
  /// SEC index.htm link from Atom feed (human-readable)
  index_url          String?

  sec_cik       String?
  sec_accession String?

  vc_firm_id String?
  vc_fund_id String?
  firm       VCFirm? @relation(fields: [vc_firm_id], references: [id], onDelete: SetNull)
  fund       VCFund? @relation(fields: [vc_fund_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([kind, filing_date])
  @@index([sec_cik])
  @@index([vc_firm_id])
  @@index([vc_fund_id])
  @@map("reg_d_filings")
}

// =============================================================================
// VCFund
// =============================================================================

model VCFund {
  id      String @id @default(cuid())
  firm_id String
  firm    VCFirm @relation(fields: [firm_id], references: [id], onDelete: Cascade)

  fund_name            String
  /// Lowercase, normalized form for dedup matching (roman→arabic, no LP/LLC suffix, collapsed whitespace).
  normalized_fund_name String?
  fund_number          Int?
  vintage_year         Int?
  open_date            DateTime? @db.Timestamptz(6)
  close_date           DateTime? @db.Timestamptz(6)

  status     FundStatus @default(ACTIVE) @map("fund_status")
  fund_type  FundType   @default(TRADITIONAL)
  source_url String?
  confidence Decimal?   @default(0.00) @db.Decimal(3, 2)

  /// Investment strategy descriptor (e.g. "early-stage B2B SaaS", "growth equity").
  strategy String? @db.Text
  /// ISO 4217 currency code (default: USD).
  currency String? @default("USD") @db.VarChar(3)

  size_usd             Float?
  aum_usd              Float?
  /// Tier from `aum_usd` / `size_usd` on this vehicle (see `AumBand`).
  aum_band             AumBand?
  committed_capital    Float?
  gp_commit_usd        Float?
  /// Stated target fund size (USD).
  target_size_usd      Float?
  /// Final close amount (USD).
  final_close_size_usd Float?

  management_fee_pct    Float?
  carry_pct             Float?
  fund_term_years       Int?
  investment_period_yrs Int?

  focus_summary      String?  @db.Text
  thesis_description String?  @db.Text
  themes             String[] @default([])

  stage_focus     StageFocus[]
  sector_focus    SectorFocus[]
  geography_focus String[]      @default([])

  prefer_to_lead        Boolean?
  lead_percentage       Float?
  co_invest_percentage  Float?
  lead_follow           LeadFollowPreference?
  reserve_for_follow_on Float?
  board_seat_preference Boolean?

  actively_deploying Boolean @default(true)

  avg_check_size_min    Float?
  avg_check_size_max    Float?
  avg_check_size_mean   Float?
  avg_check_size_median Float?

  deployment_rate       Float?
  last_investment_date  DateTime?
  investments_last_60d  Int?
  investments_last_12m  Int?
  deployed_capital_usd  Float?
  capital_remaining_usd Float?
  target_investments    Int?

  fund_match_score    Int?
  active_signal_score Int?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  investments     VCInvestment[]
  score_snapshots VCScoreSnapshot[]
  reg_d_filings   RegDFiling[]
  aliases         VCFundAlias[]
  source_evidence VCFundSourceEvidence[]

  @@unique([firm_id, normalized_fund_name])
  @@index([firm_id])
  @@index([normalized_fund_name])
  @@index([status])
  @@index([fund_type])
  @@index([actively_deploying])
  @@index([vintage_year])
  @@index([size_usd])
  @@index([aum_usd])
  @@index([aum_band])
  @@index([lead_follow])
  @@index([fund_match_score])
  @@index([deleted_at])
  @@map("vc_funds")
}

// =============================================================================
// VCPerson
// =============================================================================

model VCPerson {
  id      String @id @default(cuid())
  firm_id String
  firm    VCFirm @relation(fields: [firm_id], references: [id], onDelete: Cascade)

  first_name     String
  last_name      String
  preferred_name String?
  title          String?
  role           String?
  bio            String? @db.Text
  avatar_url     String?

  email        String?
  phone        String?
  website_url  String?
  linkedin_url String?
  x_url        String?

  city     String?
  state    String?
  country  String?
  timezone String?

  stage_focus  StageFocus[]
  sector_focus SectorFocus[]

  check_size_min Float?
  check_size_max Float?

  warm_intro_preferred Boolean @default(true)
  cold_outreach_ok     Boolean @default(false)

  personal_thesis_tags String[] @default([])
  investment_themes    String[] @default([])
  investment_style     String?
  background_summary   String?  @db.Text
  prior_firms          String[] @default([])
  education_summary    String?  @db.Text

  medium_url   String?
  substack_url String?

  /// Thought leadership articles: [{title, url, published_at, platform, summary}]
  articles Json?

  /// Timestamp of last successful team-page scrape for this person
  team_page_scraped_at DateTime? @db.Timestamptz(6)

  responsiveness_score  Int?
  recent_deal_count     Int?
  last_active_date      DateTime?
  is_actively_investing Boolean   @default(true)

  reputation_score Int?
  value_add_score  Int?
  network_strength Int?
  match_score      Int?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  /// Importer idempotency (e.g. `us-investors-920` + CSV `record_id`)
  data_source      String? @map("data_source")
  import_record_id String? @map("import_record_id")

  signals         VCSignal[]
  score_snapshots VCScoreSnapshot[]
  ratings         VCRating[]

  @@unique([data_source, import_record_id])
  @@index([firm_id])
  @@index([email])
  @@index([country, state, city])
  @@index([is_actively_investing])
  @@index([match_score])
  @@index([responsiveness_score])
  @@index([deleted_at])
  @@map("vc_people")
}

// =============================================================================
// VCRating — founder-submitted interaction scores (firm and/or partner)
// =============================================================================

model VCRating {
  id                String    @id @default(uuid())
  authorUserId      String?   @map("author_user_id")
  vcPersonId        String?   @map("vc_person_id")
  vcFirmId          String?   @map("vc_firm_id")
  interactionType   String    @map("interaction_type")
  interactionDetail String?   @map("interaction_detail") @db.Text
  interactionDate   DateTime? @map("interaction_date") @db.Date
  scoreResp         Int?      @map("score_resp")
  scoreRespect      Int?      @map("score_respect")
  scoreFeedback     Int?      @map("score_feedback")
  scoreFollowThru   Int?      @map("score_follow_thru")
  scoreValueAdd     Int?      @map("score_value_add")
  nps               Int?      @map("nps")
  comment           String?   @db.Text
  anonymous         Boolean   @default(true) @map("anonymous")
  verified          Boolean   @default(false) @map("verified")
  isDraft           Boolean   @default(false) @map("is_draft")
  /// Structured review payload: v2 answers include participant memory (`interaction_remembered_who_*`, `interaction_participant_memory_mode`). See `src/lib/reviewParticipantMemory.ts`.
  starRatings       Json      @default("{}") @map("star_ratings") @db.JsonB
  createdAt         DateTime  @default(now()) @map("created_at")

  vcPerson VCPerson? @relation(fields: [vcPersonId], references: [id], onDelete: Cascade)
  vcFirm   VCFirm?   @relation(fields: [vcFirmId], references: [id], onDelete: Cascade)

  @@index([vcPersonId, interactionType])
  @@index([vcFirmId, interactionType])
  @@index([createdAt])
  @@map("vc_ratings")
}

// =============================================================================
// Startup Data Source Enums
// =============================================================================

/// Source from which a startup record was scraped or imported.
enum StartupDataSource {
  SEEDTABLE
  TOPSTARTUPS
  TINYTEAMS
  YC
  NEXTPLAY
  STARTUPS_GALLERY
  CB_INSIGHTS
  CRUNCHBASE
  TRACXN
  MANUAL
  OTHER
}

/// Company status lifecycle.
enum StartupStatus {
  ACTIVE
  ACQUIRED
  SHUT_DOWN
  IPO
  UNKNOWN
}

/// Business model archetype.
enum BusinessModel {
  SAAS
  MARKETPLACE
  E_COMMERCE
  FINTECH_INFRA
  API_PLATFORM
  HARDWARE
  D2C
  ENTERPRISE
  CONSUMER_APP
  OPEN_SOURCE
  OTHER
}

/// Revenue range band.
enum RevenueRange {
  PRE_REVENUE
  SUB_1M
  ARR_1M_5M
  ARR_5M_10M
  ARR_10M_50M
  ARR_50M_100M
  ARR_100M_PLUS
  UNKNOWN
}

/// Founder archetype classification.
enum FounderArchetype {
  TECHNICAL
  COMMERCIAL
  HYBRID
  DOMAIN_EXPERT
  OPERATOR
  SERIAL_ENTREPRENEUR
}

/// Target customer segment.
enum TargetCustomer {
  SMB
  MID_MARKET
  ENTERPRISE
  CONSUMER
  PROSUMER
  GOVERNMENT
  OTHER
}

// =============================================================================
// Startup
// =============================================================================

model Startup {
  id                String         @id @default(cuid())
  company_name      String         @unique
  company_url       String?
  sector            SectorFocus?
  location          String?
  total_raised_usd  Decimal?       @db.Decimal(15, 2)
  last_funding_date DateTime?      @db.Date
  last_verified_at  DateTime       @default(now()) @db.Timestamptz(6)
  investments       VCInvestment[]

  // --- Company Core ---
  /// Canonical domain (lowercase, no www) — primary dedup key across sources.
  domain               String?               @unique
  description_short    String?               @db.Text
  description_long     String?               @db.Text
  logo_url             String?
  founding_date        DateTime?             @db.Date
  founded_year         Int?
  hq_city              String?
  hq_state             String?
  hq_country           String?
  geo_footprint        String[]              @default([]) /// e.g. ["US", "EU", "APAC"]
  stage                OperatorCompanyStage  @default(UNKNOWN)
  status               StartupStatus         @default(ACTIVE)
  sectors              SectorFocus[]
  secondary_sectors    String[]              @default([])
  business_model       BusinessModel?
  business_model_tags  String[]              @default([])
  headcount            Int?
  headcount_band       CompanyHeadcountBand?
  headcount_growth_pct Float? /// YoY headcount growth %
  tech_stack           String[]              @default([])

  // --- Funding & Traction ---
  last_round_size_usd Decimal?      @db.Decimal(15, 2)
  last_round_date     DateTime?     @db.Date
  last_round_type     String? /// "Seed", "Series A", etc.
  valuation_usd       Decimal?      @db.Decimal(15, 2)
  revenue_range       RevenueRange?
  /// Growth indicators
  hiring_velocity     Int? /// open roles count
  web_traffic_rank    Int? /// Similarweb / Alexa rank proxy

  // --- Investor Relationships (denormalized for fast display) ---
  investor_names      String[] @default([])
  lead_investor_names String[] @default([])
  board_members       String[] @default([])

  // --- Customer & Market ---
  target_customer    TargetCustomer?
  icp_description    String?         @db.Text
  notable_customers  String[]        @default([])
  market_category    String?
  market_subcategory String?

  // --- Derived / Computed Scores (0–100) ---
  fundraising_readiness_score Int?
  investor_fit_score          Int?
  momentum_score              Int?
  quality_of_backers_score    Int?
  likelihood_to_raise_score   Int?

  // --- Source Tracking ---
  data_sources        StartupDataSource[]
  /// Primary source that last wrote to this record.
  primary_data_source StartupDataSource?
  /// External IDs for dedup: { "yc_slug": "...", "crunchbase_uuid": "...", "topstartups_slug": "..." }
  external_ids        Json?
  data_confidence     Int? /// 0–100 composite confidence

  // --- Social links ---
  linkedin_url   String?
  x_url          String?
  github_url     String?
  crunchbase_url String?

  // --- YC-specific ---
  yc_batch String?
  yc_slug  String?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  funding_rounds   StartupFundingRound[]
  founders         StartupFounder[]
  competitors_from StartupCompetitor[]    @relation("CompetitorFrom")
  competitors_to   StartupCompetitor[]    @relation("CompetitorTo")
  signals          StartupSignal[]
  score_snapshots  StartupScoreSnapshot[]

  @@index([domain])
  @@index([stage])
  @@index([status])
  @@index([sector])
  @@index([hq_country, hq_state, hq_city])
  @@index([yc_batch])
  @@index([momentum_score])
  @@index([fundraising_readiness_score])
  @@index([primary_data_source])
  @@index([deleted_at])
  @@map("startups")
}

// =============================================================================
// StartupFundingRound — individual funding round history
// =============================================================================

model StartupFundingRound {
  id         String  @id @default(cuid())
  startup_id String
  startup    Startup @relation(fields: [startup_id], references: [id], onDelete: Cascade)

  round_name     String /// "Pre-Seed", "Seed", "Series A", etc.
  round_date     DateTime?          @db.Date
  amount_usd     Decimal?           @db.Decimal(15, 2)
  valuation_usd  Decimal?           @db.Decimal(15, 2)
  lead_investors String[]           @default([])
  participants   String[]           @default([])
  /// "lead" | "participant" tagging per investor: [{name, role}]
  investor_roles Json?
  source_url     String?
  data_source    StartupDataSource?
  confidence     Float? /// 0–1

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([startup_id, round_name, round_date])
  @@index([startup_id])
  @@index([round_date])
  @@index([round_name])
  @@map("startup_funding_rounds")
}

// =============================================================================
// StartupFounder — founder profile linked to a startup
// =============================================================================

model StartupFounder {
  id         String  @id @default(cuid())
  startup_id String
  startup    Startup @relation(fields: [startup_id], references: [id], onDelete: Cascade)

  /// Optional FK to StartupProfessional for rich graph data.
  professional_id String?

  full_name    String
  role         String? /// "CEO", "CTO", "Co-Founder", etc.
  linkedin_url String?
  x_url        String?
  location     String?
  avatar_url   String?
  email        String?

  // --- Background ---
  prior_companies     String[] @default([]) /// companies founded or worked at
  prior_exits         String[] @default([]) /// "Company (outcome)" format
  has_prior_exit      Boolean  @default(false)
  education_highlight String? /// Only signal education: "Stanford CS", "MIT MBA"
  operator_background String? /// "PM", "Eng", "Sales", "Product"
  domain_expertise    String[] @default([])

  // --- Reputation & Signal Layer ---
  is_repeat_founder     Boolean           @default(false)
  founder_archetype     FounderArchetype?
  /// operator → founder transition flag
  operator_to_founder   Boolean           @default(false)
  /// Derived track record: 0–100
  track_record_score    Int?
  /// "success" | "failure" | "partial" | "in_progress"
  prior_outcome_summary String?

  data_source StartupDataSource?
  confidence  Float? /// 0–1

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([startup_id, full_name])
  @@index([startup_id])
  @@index([professional_id])
  @@index([is_repeat_founder])
  @@index([founder_archetype])
  @@index([track_record_score])
  @@map("startup_founders")
}

// =============================================================================
// StartupCompetitor — linked company pairs
// =============================================================================

model StartupCompetitor {
  id            String  @id @default(cuid())
  startup_id    String
  competitor_id String
  startup       Startup @relation("CompetitorFrom", fields: [startup_id], references: [id], onDelete: Cascade)
  competitor    Startup @relation("CompetitorTo", fields: [competitor_id], references: [id], onDelete: Cascade)

  /// "direct" | "indirect" | "adjacent"
  relationship_type String             @default("direct")
  data_source       StartupDataSource?
  confidence        Float?

  created_at DateTime @default(now())

  @@unique([startup_id, competitor_id])
  @@index([startup_id])
  @@index([competitor_id])
  @@map("startup_competitors")
}

// =============================================================================
// StartupSignal — activity & momentum signals
// =============================================================================

model StartupSignal {
  id         String  @id @default(cuid())
  startup_id String
  startup    Startup @relation(fields: [startup_id], references: [id], onDelete: Cascade)

  /// "recent_hire" | "exec_hire" | "product_launch" | "press_mention" | "fundraising_signal" | "hiring_role"
  signal_type String
  title       String
  description String?   @db.Text
  url         String?
  signal_date DateTime? @db.Timestamptz(6)
  /// Arbitrary metadata from the source.
  metadata    Json?

  data_source      StartupDataSource?
  confidence_score Int? /// 0–100

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@index([startup_id])
  @@index([signal_type])
  @@index([signal_date])
  @@index([deleted_at])
  @@map("startup_signals")
}

// =============================================================================
// StartupScoreSnapshot — time-series scoring outputs
// =============================================================================

model StartupScoreSnapshot {
  id         String  @id @default(cuid())
  startup_id String
  startup    Startup @relation(fields: [startup_id], references: [id], onDelete: Cascade)

  fundraising_readiness Int @default(0)
  investor_fit          Int @default(0)
  momentum              Int @default(0)
  quality_of_backers    Int @default(0)
  likelihood_to_raise   Int @default(0)

  explanation   String?  @db.Text
  model_version String?
  computed_at   DateTime @default(now())

  created_at DateTime @default(now())

  @@index([startup_id])
  @@index([computed_at])
  @@map("startup_score_snapshots")
}

// =============================================================================
// VCInvestment
// =============================================================================

model VCInvestment {
  id         String  @id @default(cuid())
  firm_id    String
  fund_id    String?
  startup_id String
  firm       VCFirm  @relation(fields: [firm_id], references: [id], onDelete: Cascade)
  fund       VCFund? @relation(fields: [fund_id], references: [id], onDelete: SetNull)
  startup    Startup @relation(fields: [startup_id], references: [id], onDelete: Cascade)

