// VC platform — PostgreSQL + Prisma (core domain)
// Vector search: enable extension + column via raw SQL after first migrate; see repo notes from your architect.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums (filtering / consistency) ---

enum FirmType {
  VC
  CVC
  ANGEL_NETWORK
  MICRO_FUND
  FAMILY_OFFICE
  PE
  ACCELERATOR
  OTHER
}

enum FundStatus {
  ACTIVE
  CLOSED
  FORMING
  WINDING_DOWN
}

enum FundType {
  TRADITIONAL
  ROLLING
  SYNDICATE
  MICRO
  CVC
  FAMILY_OFFICE
}

enum LeadFollowPreference {
  LEAD_ONLY
  LEAD_PREFERRED
  FOLLOW_ONLY
  FLEXIBLE
}

enum StageFocus {
  PRE_SEED
  SEED
  SERIES_A
  SERIES_B
  SERIES_C
  GROWTH
  LATE
  IPO
}

enum SectorFocus {
  FINTECH
  ENTERPRISE_SAAS
  AI
  HEALTHTECH
  BIOTECH
  CONSUMER
  CLIMATE
  MOBILITY
  INDUSTRIAL
  CYBERSECURITY
  MEDIA
  WEB3
  EDTECH
  GOVTECH
  HARDWARE
  ROBOTICS
  MARKETPLACE
  AGRITECH
  PROPTECH
  OTHER
}

enum SourceType {
  CRUNCHBASE
  CB_INSIGHTS
  SIGNAL_NFX
  VCSHEET
  VC_PRO_DATABASE
  VENTUREXPERT
  ANGELLIST
  OPENVC
  TRUSTFINTA
  OTHER
}

/// Alternate identifiers for a VC firm — dedupe imports and resolve merged / renamed entities.
enum VCFirmAliasType {
  WEBSITE_DOMAIN
  SLUG
  LEGAL_NAME
  ALSO_KNOWN_AS
  CRUNCHBASE_SLUG
  CRUNCHBASE_UUID
  LINKEDIN_COMPANY_SLUG
  LINKEDIN_NUMERIC_ID
  EMAIL_DOMAIN
  EXTERNAL_REF
  MANUAL
}

/// SEC Regulation D primary_doc.xml — pooled fund vs operating company.
enum RegDFilingKind {
  VC_FUND
  STARTUP
}

/// Activity category for VCSignal (recent investments, team changes, content, events, deployment)
enum SignalType {
  RECENT_INVESTMENT
  HIRE
  DEPARTURE
  BLOG_POST
  EVENT
  DEPLOYMENT_UPDATE
  OTHER
}

enum ExitType {
  IPO
  ACQUISITION
  SECONDARY
  SHUTDOWN
  STILL_PRIVATE
  UNKNOWN
}

enum InvestmentLifecycleStatus {
  ACTIVE
  EXITED
  WRITTEN_OFF
  UNKNOWN
}

enum DeadLetterStatus {
  PENDING_RETRY    @map("Pending Retry")
  FAILED_PERMANENT @map("Failed Permanent")
  RESOLVED         @map("Resolved")
}

// =============================================================================
// VCFirm
// =============================================================================

model VCFirm {
  id String @id @default(cuid())

  firm_name      String
  legal_name     String?
  slug           String  @unique
  logo_url       String?
  elevator_pitch String?
  description    String? @db.Text

  website_url String?
  email       String?
  phone       String?
  address     String?

  hq_city    String?
  hq_state   String?
  hq_country String?
  locations  Json?

  x_url         String?
  linkedin_url  String?
  substack_url  String?
  medium_url    String?
  beehiiv_url   String?
  instagram_url String?
  facebook_url  String?
  youtube_url   String?
  tiktok_url    String?

  crunchbase_url    String?
  cb_insights_url   String?
  signal_nfx_url    String?
  vcsheet_url       String?
  vcprodatabase_url String?
  venturexpert_url  String?
  angellist_url     String?
  openvc_url        String?
  trustfinta_url    String?

  total_headcount       Int?
  total_investors       Int?
  total_partners        Int?
  general_partner_count Int?
  partner_names         String[] @default([])
  general_partner_names String[] @default([])

  firm_type             FirmType @default(VC)
  founded_year          Int?
  status                String?
  verification_status   String?
  data_confidence_score Int?

  reputation_score     Int?
  founder_sentiment    Int?
  industry_reputation  Int?
  responsiveness_score Int?
  value_add_score      Int?
  network_strength     Int?
  match_score          Int?

  /// Gemini text-embedding-004 (768-dim) of elevator_pitch / thesis.
  /// Written by the AI enrichment worker; use raw SQL or pg client for vector ops.
  thesis_embedding Unsupported("vector(768)")?

  /// 1 = mega-fund (slow decay), 2 = mid-size, 3 = micro-fund (fast decay)
  volatility_score         Int      @default(1)
  last_verified_at         DateTime @default(now()) @db.Timestamptz(6)
  next_update_scheduled_at DateTime @default(dbgenerated("(now() + '30 days'::interval)")) @db.Timestamptz(6)

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  funds              VCFund[]
  people             VCPerson[]
  signals            VCSignal[]
  recent_investments VCInvestment[]
  source_links       VCSourceLink[]
  score_snapshots    VCScoreSnapshot[]
  ratings            VCRating[]
  aliases            VCFirmAlias[]
  reg_d_filings      RegDFiling[]

  @@index([firm_name])
  @@index([firm_type])
  @@index([hq_country, hq_state, hq_city])
  @@index([match_score])
  @@index([reputation_score])
  @@index([founder_sentiment])
  @@index([industry_reputation])
  @@index([next_update_scheduled_at])
  @@index([deleted_at])
  @@map("vc_firms")
}

/// Maps normalized alternate keys (domains, slugs, legal names, vendor IDs) to the canonical `vc_firms` row.
/// Store `alias_value` in a consistent normalized form (e.g. lowercase host without `www.`).
model VCFirmAlias {
  id      String @id @default(cuid())
  firm_id String
  firm    VCFirm @relation(fields: [firm_id], references: [id], onDelete: Cascade)

  alias_type  VCFirmAliasType
  alias_value String          @db.Text

  /// Provenance: importer name, "merge", "admin", etc.
  source     String?
  notes      String? @db.Text
  /// Optional match strength for fuzzy / heuristic links (0–1).
  confidence Float?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([alias_type, alias_value])
  @@index([firm_id])
  @@index([alias_value])
  @@map("vc_firm_aliases")
}

/// Parsed SEC Form D filing (Regulation D). VC_FUND rows link to vc_firms + vc_funds; STARTUP rows stand in for issuer “company” until claimed in product.
model RegDFiling {
  id                 String         @id @default(cuid())
  kind               RegDFilingKind
  entity_name        String
  industry_group     String?        @db.Text
  total_offering_raw String?        @map("total_offering_raw") @db.Text
  amount_raised_usd  Float?
  filing_date        DateTime?
  /// primary_doc.xml URL (unique ingestion key)
  source_url         String         @unique
  /// SEC index.htm link from Atom feed (human-readable)
  index_url          String?

  sec_cik       String?
  sec_accession String?

  vc_firm_id String?
  vc_fund_id String?
  firm       VCFirm? @relation(fields: [vc_firm_id], references: [id], onDelete: SetNull)
  fund       VCFund? @relation(fields: [vc_fund_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([kind, filing_date])
  @@index([sec_cik])
  @@index([vc_firm_id])
  @@index([vc_fund_id])
  @@map("reg_d_filings")
}

// =============================================================================
// VCFund
// =============================================================================

model VCFund {
  id      String @id @default(cuid())
  firm_id String
  firm    VCFirm @relation(fields: [firm_id], references: [id], onDelete: Cascade)

  fund_name    String
  fund_number  Int?
  vintage_year Int?
  open_date    DateTime? @db.Timestamptz(6)
  close_date   DateTime? @db.Timestamptz(6)

  status     FundStatus @default(ACTIVE) @map("fund_status")
  fund_type  FundType   @default(TRADITIONAL)
  source_url String?
  confidence Decimal?   @default(0.00) @db.Decimal(3, 2)

  size_usd          Float?
  aum_usd           Float?
  committed_capital Float?
  gp_commit_usd     Float?

  management_fee_pct    Float?
  carry_pct             Float?
  fund_term_years       Int?
  investment_period_yrs Int?

  focus_summary      String?  @db.Text
  thesis_description String?  @db.Text
  themes             String[] @default([])

  stage_focus     StageFocus[]
  sector_focus    SectorFocus[]
  geography_focus String[]      @default([])

  prefer_to_lead        Boolean?
  lead_percentage       Float?
  co_invest_percentage  Float?
  lead_follow           LeadFollowPreference?
  reserve_for_follow_on Float?
  board_seat_preference Boolean?

  actively_deploying Boolean @default(true)

  avg_check_size_min    Float?
  avg_check_size_max    Float?
  avg_check_size_mean   Float?
  avg_check_size_median Float?

  deployment_rate       Float?
  last_investment_date  DateTime?
  investments_last_60d  Int?
  investments_last_12m  Int?
  deployed_capital_usd  Float?
  capital_remaining_usd Float?
  target_investments    Int?

  fund_match_score    Int?
  active_signal_score Int?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  investments     VCInvestment[]
  score_snapshots VCScoreSnapshot[]
  reg_d_filings   RegDFiling[]

  @@index([firm_id])
  @@index([status])
  @@index([fund_type])
  @@index([actively_deploying])
  @@index([vintage_year])
  @@index([size_usd])
  @@index([aum_usd])
  @@index([lead_follow])
  @@index([fund_match_score])
  @@index([deleted_at])
  @@map("vc_funds")
}

// =============================================================================
// VCPerson
// =============================================================================

model VCPerson {
  id      String @id @default(cuid())
  firm_id String
  firm    VCFirm @relation(fields: [firm_id], references: [id], onDelete: Cascade)

  first_name     String
  last_name      String
  preferred_name String?
  title          String?
  role           String?
  bio            String? @db.Text
  avatar_url     String?

  email        String?
  phone        String?
  website_url  String?
  linkedin_url String?
  x_url        String?

  city     String?
  state    String?
  country  String?
  timezone String?

  stage_focus  StageFocus[]
  sector_focus SectorFocus[]

  check_size_min Float?
  check_size_max Float?

  warm_intro_preferred Boolean @default(true)
  cold_outreach_ok     Boolean @default(false)

  personal_thesis_tags String[] @default([])
  investment_style     String?
  background_summary   String?  @db.Text
  prior_firms          String[] @default([])
  education_summary    String?  @db.Text

  responsiveness_score  Int?
  recent_deal_count     Int?
  last_active_date      DateTime?
  is_actively_investing Boolean   @default(true)

  reputation_score Int?
  value_add_score  Int?
  network_strength Int?
  match_score      Int?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  /// Importer idempotency (e.g. `us-investors-920` + CSV `record_id`)
  data_source      String? @map("data_source")
  import_record_id String? @map("import_record_id")

  signals         VCSignal[]
  score_snapshots VCScoreSnapshot[]
  ratings         VCRating[]

  @@unique([data_source, import_record_id])
  @@index([firm_id])
  @@index([email])
  @@index([country, state, city])
  @@index([is_actively_investing])
  @@index([match_score])
  @@index([responsiveness_score])
  @@index([deleted_at])
  @@map("vc_people")
}

// =============================================================================
// VCRating — founder-submitted interaction scores (firm and/or partner)
// =============================================================================

model VCRating {
  id                String    @id @default(uuid())
  authorUserId      String?   @map("author_user_id")
  vcPersonId        String?   @map("vc_person_id")
  vcFirmId          String?   @map("vc_firm_id")
  interactionType   String    @map("interaction_type")
  interactionDetail String?   @map("interaction_detail") @db.Text
  interactionDate   DateTime? @map("interaction_date") @db.Date
  scoreResp         Int?      @map("score_resp")
  scoreRespect      Int?      @map("score_respect")
  scoreFeedback     Int?      @map("score_feedback")
  scoreFollowThru   Int?      @map("score_follow_thru")
  scoreValueAdd     Int?      @map("score_value_add")
  nps               Int?      @map("nps")
  comment           String?   @db.Text
  anonymous         Boolean   @default(true) @map("anonymous")
  verified          Boolean   @default(false) @map("verified")
  isDraft           Boolean   @default(false) @map("is_draft")
  /// Structured review payload: v2 answers include participant memory (`interaction_remembered_who_*`, `interaction_participant_memory_mode`). See `src/lib/reviewParticipantMemory.ts`.
  starRatings       Json      @default("{}") @map("star_ratings") @db.JsonB
  createdAt         DateTime  @default(now()) @map("created_at")

  vcPerson VCPerson? @relation(fields: [vcPersonId], references: [id], onDelete: Cascade)
  vcFirm   VCFirm?   @relation(fields: [vcFirmId], references: [id], onDelete: Cascade)

  @@index([vcPersonId, interactionType])
  @@index([vcFirmId, interactionType])
  @@index([createdAt])
  @@map("vc_ratings")
}

// =============================================================================
// Startup
// =============================================================================

model Startup {
  id                String         @id @default(cuid())
  company_name      String         @unique
  company_url       String?
  sector            SectorFocus?
  location          String?
  total_raised_usd  Decimal?       @db.Decimal(15, 2)
  last_funding_date DateTime?      @db.Date
  last_verified_at  DateTime       @default(now()) @db.Timestamptz(6)
  investments       VCInvestment[]

  @@map("startups")
}

// =============================================================================
// VCInvestment
// =============================================================================

model VCInvestment {
  id         String  @id @default(cuid())
  firm_id    String
  fund_id    String?
  startup_id String
  firm       VCFirm  @relation(fields: [firm_id], references: [id], onDelete: Cascade)
  fund       VCFund? @relation(fields: [fund_id], references: [id], onDelete: SetNull)
  startup    Startup @relation(fields: [startup_id], references: [id], onDelete: Cascade)

  round_type      StageFocus?
  check_size_usd  Decimal?    @db.Decimal(15, 2)
  led_round       Boolean     @default(false)
  investment_date DateTime?   @db.Timestamptz(6)
  source_url      String?
  confidence      Decimal?    @default(0.00) @db.Decimal(3, 2)

  @@unique([firm_id, startup_id, round_type])
  @@index([firm_id])
  @@index([fund_id])
  @@index([startup_id])
  @@index([investment_date])
  @@index([check_size_usd])
  @@map("vc_investments")
}

// =============================================================================
// VCSourceLink
// =============================================================================

model VCSourceLink {
  id      String @id @default(cuid())
  firm_id String
  firm    VCFirm @relation(fields: [firm_id], references: [id], onDelete: Cascade)

  source_type SourceType
  label       String
  url         String

  last_verified_at DateTime?
  confidence_score Int?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@index([firm_id])
  @@index([source_type])
  @@index([last_verified_at])
  @@index([deleted_at])
  @@map("vc_source_links")
}

// =============================================================================
// VCSignal
// =============================================================================

model VCSignal {
  id      String @id @default(cuid())
  firm_id String
  firm    VCFirm @relation(fields: [firm_id], references: [id], onDelete: Cascade)

  person_id String?
  person    VCPerson? @relation(fields: [person_id], references: [id], onDelete: SetNull)

  signal_type SignalType

  title       String
  url         String?
  description String?   @db.Text
  signal_date DateTime?

  source_type       SourceType?
  source_confidence Int?
  metadata          Json?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@index([firm_id])
  @@index([person_id])
  @@index([signal_type])
  @@index([signal_date])
  @@index([source_type])
  @@index([deleted_at])
  @@map("vc_signals")
}

// =============================================================================
// VCScoreSnapshot (time-series / model outputs)
// =============================================================================

model VCScoreSnapshot {
  id String @id @default(cuid())

  firm_id   String
  person_id String?
  fund_id   String?

  firm   VCFirm    @relation(fields: [firm_id], references: [id], onDelete: Cascade)
  person VCPerson? @relation(fields: [person_id], references: [id], onDelete: SetNull)
  fund   VCFund?   @relation(fields: [fund_id], references: [id], onDelete: SetNull)

  match_score          Int @default(0)
  reputation_score     Int @default(0)
  founder_sentiment    Int @default(0)
  industry_reputation  Int @default(0)
  responsiveness_score Int @default(0)
  founder_satisfaction Int @default(0)
  value_add_ability    Int @default(0)
  network_strength     Int @default(0)
  active_deployment    Int @default(0)

  explanation   String?  @db.Text
  model_version String?
  computed_at   DateTime @default(now())

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@index([firm_id])
  @@index([person_id])
  @@index([fund_id])
  @@index([computed_at])
  @@index([match_score])
  @@index([reputation_score])
  @@index([deleted_at])
  @@map("vc_score_snapshots")
}

// =============================================================================
// StartupProfessional — non-investor operators (founders, CTOs, makers) for intel
// =============================================================================

model StartupProfessional {
  id              String    @id @default(uuid())
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  fullName        String    @map("full_name")
  linkedin        String?   @unique
  email           String?
  title           String
  currentRole     String    @map("current_role")
  currentStartup  String    @map("current_startup")
  prevStartups    String[]  @default([]) @map("prev_startups")
  ycBatch         String?   @map("yc_batch")
  phMaker         Boolean   @default(false) @map("ph_maker")
  /// Posts shipped as maker (for “2+ launches” style filters)
  phLaunchCount   Int       @default(0) @map("ph_launch_count")
  githubHandle    String?   @map("github_handle")
  githubStars     Int       @default(0) @map("github_stars")
  angelListId     String?   @map("angel_list_id")
  followers       Int       @default(0)
  location        String?
  /// Last writer source label for this ingest (audit log has full history)
  source          String
  /// Max sourcePriority applied to this row (trust / merge precedence)
  sourcePriority  Int       @default(0) @map("source_priority")
  lastSeenAt      DateTime? @map("last_seen_at")
  sourceUpdatedAt DateTime? @map("source_updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  changeLogs StartupProfessionalChangeLog[]

  @@unique([fullName, currentStartup], map: "startup_professionals_full_name_current_startup_key")
  @@index([ycBatch])
  @@index([currentRole])
  @@index([source])
  @@index([sourcePriority])
  @@index([githubStars])
  @@index([location])
  @@index([phLaunchCount])
  @@index([lastSeenAt])
  @@map("startup_professionals")
}

/// Field-level history (legacy) plus optional `patch` JSON for one ingest transaction.
model StartupProfessionalChangeLog {
  id                    String   @id @default(uuid())
  startupProfessionalId String   @map("startup_professional_id")
  /// Use "*" when `patch` holds a batch of changes
  field                 String
  oldValue              String?  @map("old_value")
  newValue              String?  @map("new_value")
  source                String
  sourcePriority        Int      @default(0) @map("source_priority")
  patch                 Json?
  createdAt             DateTime @default(now()) @map("created_at")

  startupProfessional StartupProfessional @relation(fields: [startupProfessionalId], references: [id], onDelete: Cascade)

  @@index([startupProfessionalId])
  @@index([createdAt])
  @@map("startup_professional_changelogs")
}

/// Dead-letter queue for failed ingest / enrichment operations.
/// Stores raw payloads so failed writes can be retried or resolved manually.
model DeadLetterQueue {
  id String @id @default(uuid()) @db.Uuid

  target_table String
  target_id    String?

  failed_operation String
  error_message    String? @db.Text
  raw_payload      Json?

  retry_count Int              @default(0)
  status      DeadLetterStatus @default(PENDING_RETRY)

  failed_at   DateTime  @default(now()) @db.Timestamptz(6)
  resolved_at DateTime? @db.Timestamptz(6)

  @@index([status, failed_at])
  @@index([target_table, target_id])
  @@map("dead_letter_queue")
}
