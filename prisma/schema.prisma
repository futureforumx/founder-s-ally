// VC platform — PostgreSQL + Prisma (core domain)
// Vector search: enable extension + column via raw SQL after first migrate; see repo notes from your architect.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums (filtering / consistency) ---

enum FirmType {
  VC
  CVC
  ANGEL_NETWORK
  MICRO_FUND
  MICRO_VC
  FAMILY_OFFICE
  PE
  ACCELERATOR
  OTHER
  INSTITUTIONAL
  SOLO_GP
  PUBLIC
  VENTURE_STUDIO
}

