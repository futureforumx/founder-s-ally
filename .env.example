# ─────────────────────────────────────────────────────────────────
# Front-end / Vite env vars
# ─────────────────────────────────────────────────────────────────

# Supabase project URL (https://<PROJECT_REF>.supabase.co)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon / publishable key (safe to expose to the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>

# Supabase project ID / ref
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# Clerk (browser — use VITE_ prefix for Vite; not NEXT_PUBLIC_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_or_pk_live_...

# After adding Clerk, configure Supabase to accept Clerk JWTs (third-party auth) so RLS works:
# https://supabase.com/docs/guides/auth/third-party/clerk
# In Clerk: optional JWT template named "supabase" if your project uses getToken({ template: 'supabase' }).

# ─────────────────────────────────────────────────────────────────
# Supabase clone pipeline (GitHub Actions secrets — NOT for .env)
# Set these in: Settings → Secrets and variables → Actions
# ─────────────────────────────────────────────────────────────────

# Supabase CLI personal access token (supabase.com/dashboard → Account → Access Tokens)
# SUPABASE_ACCESS_TOKEN=

# ── Source project ────────────────────────────────────────────────
# SRC_PROJECT_REF=fuxzlmporikuhotzcqyc
# SRC_SUPABASE_URL=https://fuxzlmporikuhotzcqyc.supabase.co
# SRC_SUPABASE_SERVICE_ROLE_KEY=

# SRC_DB_HOST=db.fuxzlmporikuhotzcqyc.supabase.co
# SRC_DB_PORT=5432
# SRC_DB_NAME=postgres
# SRC_DB_USER=postgres
# SRC_DB_PASSWORD=

# ── Destination project ───────────────────────────────────────────
# DST_PROJECT_REF=awdtlonduhrpvxerrmst
# DST_SUPABASE_URL=https://awdtlonduhrpvxerrmst.supabase.co
# DST_SUPABASE_SERVICE_ROLE_KEY=

# DST_DB_HOST=db.awdtlonduhrpvxerrmst.supabase.co
# DST_DB_PORT=5432
# DST_DB_NAME=postgres
# DST_DB_USER=postgres
# DST_DB_PASSWORD=

# ─────────────────────────────────────────────────────────────────
# Edge function secrets (set via `supabase secrets set` or the dashboard)
# ─────────────────────────────────────────────────────────────────
# SUPABASE_URL=           (injected automatically by Supabase runtime)
# SUPABASE_ANON_KEY=      (injected automatically)
# SUPABASE_SERVICE_ROLE_KEY= (injected automatically)
# LOVABLE_API_KEY=
# EXA_API_KEY=
# NFX_API_KEY=
