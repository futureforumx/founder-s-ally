# Supabase (database, storage, edge functions)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Clerk (authentication). Use VITE_ prefix — not NEXT_PUBLIC_ (this app is Vite).
VITE_CLERK_PUBLISHABLE_KEY=
# Optional: pk_test_… for local dev when production key is pk_live_
VITE_CLERK_PUBLISHABLE_KEY_DEV=

# Optional: bypass auth with a demo user (no Clerk)
# VITE_DEMO_MODE=true
