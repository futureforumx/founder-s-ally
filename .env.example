# Supabase (database, storage, edge functions)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase project URL (https://<PROJECT_REF>.supabase.co)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
#
# If the app or edge functions error with: "Could not find the table 'public.company_analyses' in the schema cache",
# your Supabase Postgres database does not have the app schema yet. Apply repo migrations to the SAME project as this URL:
#   npm run supabase -- login
#   npm run supabase -- link --project-ref <same-ref-as-in-URL>
#   npm run supabase:db:push
# (Do not confuse this with `npm run db:push` — that is Prisma for DATABASE_URL / VC tables, not supabase/migrations.)

# Supabase anon / publishable key (safe to expose to the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>
# Optional: legacy anon JWT (eyJ…) if PUBLISHABLE_KEY is sb_publishable_… — Edge Functions JWT gateway needs a JWT Bearer; see src/lib/waitlist.ts
# VITE_SUPABASE_ANON_KEY=

# Supabase project ID / ref
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# Personal access token for Supabase CLI (deploy edge functions from your machine / CI).
# Required for public waitlist/snapshot endpoints when using sb_publishable_ keys (fixes HTTP 401 from Edge gateway).
# Create: https://supabase.com/dashboard/account/tokens — then: npm run supabase:functions
# Deploys: waitlist-signup, waitlist-status, founder-waitlist-snapshot (all --no-verify-jwt).
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mixpanel (browser — optional override; app defaults to the bundled project token)
# VITE_MIXPANEL_TOKEN=

# Exa (batch scripts only — HQ + AUM enrichment for firm_records)
# Key: https://dashboard.exa.ai/api-keys — use in .env.local; never commit.
# EXA_API_KEY=
# Optional: EXA_SEARCH_TYPE=deep (default) | deep-lite | fast — ENRICH_MAX=80 ENRICH_FORCE=1 ENRICH_FIRM_IDS=<uuid>,<uuid>
# After migration `supabase/migrations/20260414120000_firm_records_canonical_hq_governance.sql`:
# ENRICH_PATCH_CANONICAL_HQ=1

# Fresh Capital public page (`/fresh-capital`)
# Demo rows: non-production builds only. Never used when import.meta.env.PROD is true.
# VITE_FRESH_CAPITAL_DEMO=true
# Optional: override signup path/query for conversion CTAs (defaults: /auth/sign-up + signup_attribution=fresh_capital)
# VITE_FRESH_CAPITAL_SIGNUP_PATH=/auth/sign-up
# VITE_FRESH_CAPITAL_SIGNUP_QUERY=

# Auth provider switch: keep `clerk` during migration, or set `workos` to enable WorkOS AuthKit in the app.
VITE_AUTH_PROVIDER=clerk
#
# WorkOS AuthKit (used when VITE_AUTH_PROVIDER=workos)
# Dashboard setup:
# - Redirect URI: https://your-app/auth
# - Sign-in endpoint: https://your-app/auth
# - CORS: allow your local and production origins
# Docs: https://workos.com/docs/authkit/client-only
# VITE_WORKOS_CLIENT_ID=client_123456789
# Recommended with a custom auth domain:
# VITE_WORKOS_API_HOSTNAME=auth.vekta.so
# Local/dev fallback if you have no custom auth domain yet:
# VITE_WORKOS_DEV_MODE=true
# Optional explicit redirect URI reference:
# VITE_WORKOS_REDIRECT_URI=http://localhost:5173/auth

# Clerk (browser — use VITE_ prefix for Vite; not NEXT_PUBLIC_)
#
# Recommended: keep **production** key here for deploys, and put your **Development** key in _DEV below.
# When you run `npm run dev`, the app uses VITE_CLERK_PUBLISHABLE_KEY_DEV if set (pk_test_…).
# Production builds ignore _DEV and use VITE_CLERK_PUBLISHABLE_KEY, except on Vercel Preview:
# If `VERCEL_ENV=preview` at build time, `VITE_CLERK_PUBLISHABLE_KEY_PREVIEW` is used when set (pk_test_…),
# so Preview can use Clerk Development keys while Production keeps pk_live_ on VITE_CLERK_PUBLISHABLE_KEY.
# `VITE_VERCEL_ENV` is injected from VERCEL_ENV in vite.config — do not set it manually.
#
# Local file: copy these lines into `.env.local` (gitignored) and restart Vite.
#
# If you have no Clerk key yet, you can set VITE_DEMO_MODE=true in `.env.local` to run with a demo user
# (no ClerkProvider). Add a real pk_test_ key when ready for sign-in.
#
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Vercel Preview only — Clerk Development publishable key (add in Vercel with Preview scope)
# VITE_CLERK_PUBLISHABLE_KEY_PREVIEW=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Clerk Dashboard → Development → API Keys → publishable key (pk_test_…)
VITE_CLERK_PUBLISHABLE_KEY_DEV=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
#
# Supabase Edge Functions secret (not VITE_): supabase secrets set CLERK_SECRET_KEY — use the Clerk **secret** key from the dashboard (same Clerk instance as the publishable keys above; powers admin user list).
# CLERK_SECRET_KEY=
# VITE_DEMO_MODE=true

# Auth split layout: optional hero videos (full-bleed right column on md+; object-fit cover).
# Mux: comma-separated playback IDs and/or full https://player.mux.com/{id} URLs. These play first, then built-in defaults rotate.
# VITE_AUTH_MUX_PLAYBACK_IDS=
# VITE_AUTH_MUX_PLAYBACK_IDS_SIGNIN=
# VITE_AUTH_MUX_PLAYBACK_IDS_SIGNUP=
# Direct file URLs (mp4/webm) still use a plain <video> tag (no Mux rotation).
# VITE_AUTH_VIDEO_URL is used when the route-specific URL is unset.
# VITE_AUTH_VIDEO_SIGNIN=
# VITE_AUTH_VIDEO_SIGNUP=
# VITE_AUTH_VIDEO_URL=

# /access page: background MP4 (defaults to pub-894f…r2.dev + fixed filename in src/lib/accessPageVideoUrl.ts).
# VITE_ACCESS_PAGE_BG_VIDEO_URL=https://example.com/custom-path/video.mp4
# VITE_ACCESS_PAGE_VIDEO_CDN_BASE=https://your-r2-public-host   # no trailing slash; app appends the access video filename

# After adding Clerk, configure Supabase third-party auth so PostgREST RLS works (required for direct table access):
# https://supabase.com/docs/guides/auth/third-party/clerk
# Recommended: Supabase Dashboard → Authentication → Third-party auth → Clerk (Clerk Frontend API + secret).
# The app sends the Clerk session JWT first, then (if needed) a JWT template named **supabase**.
# If a broken `supabase` template was shadowing a good session token, session-first fixes firm profile / vc_* reads.
# Legacy template-first order: set VITE_SUPABASE_JWT_TEMPLATE_FIRST=true in .env.local
# Session only (never send template): VITE_USE_CLERK_SESSION_JWT_FOR_SUPABASE=true
# Without a verifiable JWT, you see RLS errors or "No suitable key or wrong key type" / PGRST301.
# Workspace creation can use the create-company-workspace edge function when deployed; direct DB inserts need a valid JWT.
# If that function is missing/404 locally, the app falls back to direct inserts — those fail RLS until Clerk third-party
# auth (and/or template + RLS) is configured, or the function is deployed with secrets.

# ─────────────────────────────────────────────────────────────────
# Supabase clone pipeline (GitHub Actions secrets — NOT for .env)
# Set these in: Settings → Secrets and variables → Actions
# ─────────────────────────────────────────────────────────────────

# Supabase CLI personal access token (supabase.com/dashboard → Account → Access Tokens)
# SUPABASE_ACCESS_TOKEN=

