# DST_DB_NAME=postgres
# DST_DB_USER=postgres
# DST_DB_PASSWORD=

# ─────────────────────────────────────────────────────────────────
# Edge function secrets (set via `supabase secrets set` or the dashboard)
# ─────────────────────────────────────────────────────────────────
# SUPABASE_URL=           (injected automatically by Supabase runtime)
# SUPABASE_ANON_KEY=      (injected automatically)
# SUPABASE_SERVICE_ROLE_KEY= (injected automatically)
# LOOPS_API_KEY=          # Used by investor-waitlist edge function (onboarding investor form)
# LOVABLE_API_KEY=
# investor-updates: optional news APIs (set on the function; all parallel, results merged + deduped)
# NEWS_API_KEY=                    # https://newsapi.org
# MEDIASTACK_ACCESS_KEY=           # https://mediastack.com
# GNEWS_API_KEY=                   # https://gnews.io
# THE_NEWS_API_TOKEN=              # https://www.thenewsapi.com
# REFRESH_NEWS_CRON_TOKEN=         # Optional bearer token guard for refresh-firm-news
# EXA_API_KEY=
# Deploy edge functions (service role; work with Clerk session JWT — no Supabase JWT template required for these paths):
#   supabase functions deploy create-company-workspace
#   supabase functions deploy claim-company-workspace
#   supabase functions deploy complete-founder-onboarding
# research-agent: multi-tier search (Tavily → Exa), Jina Reader + Rerank, Scrapeless on blocks, Groq (chat) / Gemini (reason)
# TAVILY_API_KEY=          # Tavily search: edge research-agent, scripts/vc_enrich_gemini.py, scripts/investor_news_refresh.py
# JINA_API_KEY=
# GEMINI_API_KEY=          # Google AI Studio / Gemini API (also: scripts/vc_enrich_gemini.py, scripts/investor_news_refresh.py)
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_API_KEY=
# SCRAPELESS_API_TOKEN=
# SCRAPELESS_ACTOR=   # Scrapeless dashboard actor id for generic URL fetch (e.g. browser/html scraper)
# Bing Web Search v7 (Azure AI — Ocp-Apim-Subscription-Key). Web SERP backup (same family as “Google search” results): exa-search when Exa fails; semantic-search (omnibar) when AI is down / empty / rate-limited. Key is often 32 hex chars.
# BING_SEARCH_API_KEY=
# NFX_API_KEY=
# RapidAPI key (subscribe to: LI Data Scraper, linkedin-api8, Alpha Vantage on RapidAPI). Used by:
# - sync-linkedin-profile: li-data-scraper → linkedin-api8 similar-profiles → SCRAPINGDOG_API_KEY
# - market-updates (TIME_SERIES_DAILY backup when Lovable AI gateway fails or is unset)
# RAPIDAPI_KEY=

# ─────────────────────────────────────────────────────────────────
# Prisma (VC schema — prisma/schema.prisma)
# ─────────────────────────────────────────────────────────────────
# Prisma CLI (`migrate`, `generate`, `studio`, `db seed`) loads `.env` from the project root by default,
# not Vite’s `.env.local`. Put DATABASE_URL here, or symlink: `ln -sf .env.local .env` (keep `.env` gitignored).
#
# Direct Postgres connection string (not the Supabase REST URL). Use pooler or session mode as needed.
# Example (Supabase): postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
#
# SEC Form D sync (`npm run sec:form-d` — `scripts/sec_form_d_sync.py`). Required by SEC: descriptive User-Agent with contact email.
# python3 -m pip install -r scripts/requirements-sec-form-d.txt
# SEC_USER_AGENT=VektaApp (you@company.com)
# SEC_FORM_D_LIMIT=15
# SEC_FORM_D_DRY_RUN=1   # parse only, no DATABASE_URL writes
# SEC_FORM_D_VERBOSE=1   # debug SEC feed / entry count
# If Postgres connect fails with idna/UnicodeError: URL-encode @ in the password as %40; strip line breaks from DATABASE_URL.
#
# Hunter.io — optional email enrichment for `vc_people` (`npm run db:enrich:emails`). Uses REST v2 (no npm package required).
# https://hunter.io/api_keys
# HUNTER_API_KEY=
# ENRICH_EMAILS_MAX=50
# ENRICH_EMAILS_DELAY_MS=600
#
# Email waterfall enrichment (`npm run db:enrich:emails:waterfall`) for missing firm + person emails.
# The script reads both `.env` and `.env.local`, so put real secrets in `.env.local`.
# Run examples:
#   npm run db:enrich:emails:waterfall
#   ENRICH_EMAILS_DRY_RUN=1 npm run db:enrich:emails:waterfall
#   ENRICH_EMAILS_MAX_PEOPLE=500 ENRICH_EMAILS_MAX_FIRMS=300 ENRICH_EMAILS_DELAY_MS=0 npm run db:enrich:emails:waterfall
#
# Generic controls:
# ENRICH_EMAILS_SOURCE=us-investors-920      # optional filter by vc_people.data_source
# ENRICH_EMAILS_MAX_PEOPLE=400
# ENRICH_EMAILS_MAX_FIRMS=250
# ENRICH_EMAILS_DELAY_MS=180
# ENRICH_EMAILS_TIMEOUT_MS=18000
# ENRICH_EMAILS_DRY_RUN=1
#
# Provider keys (script supports the aliases shown in parentheses):
# APOLLO_API_KEY=                          # alias: APOLLO_API
# PEOPLE_DATA_LABS_API_KEY=                # aliases: PDL_API_KEY, PEOPLEDATALABS_API_KEY
# CLAY_API_KEY=                            # alias: CLAY_API
# HUNTER_API_KEY=                          # alias: HUNTER_API
# LUSHA_API_KEY=                           # alias: LUSHA_API
# EXA_API_KEY=                             # alias: EXA_AI_API_KEY
# JINA_API_KEY=                            # alias: JINA_API
# TAVILY_API_KEY=                          # alias: TAVILY_API
# LINKUP_API_KEY=                          # alias: LINKUP_API
# SCRAPELESS_API_KEY=                      # aliases: SCRAPELESS_API, SCRAPELESS_API_TOKEN
# GROQ_API_KEY=                            # alias: GROQ_API
# GEMINI_API_KEY=                          # aliases: GEMINI_25_API_KEY, GEMINI_API
# DEEPSEEK_API_KEY=                        # alias: DEEPSEEK_API
#
# Provider endpoints required for account-specific HTTP workflows:
# LUSHA_PERSON_URL=
# LUSHA_FIRM_URL=
# CLAY_PERSON_URL=
# CLAY_FIRM_URL=
# LINKUP_SEARCH_URL=
# SCRAPELESS_PERSON_URL=
# SCRAPELESS_FIRM_URL=
#
# AngelList Relay API (portfolio sync — `npm run db:seed:angellist`). Not a public investor directory.
# https://docs.angellist.com/docs/endpoints
# ANGELLIST_RELAY_API_KEY=
# RELAY_PORTFOLIO_FIRM_SLUG=angellist-relay
# RELAY_FETCH_INVESTMENT_DETAILS=true
#
# OpenVC-shaped JSON import (`npm run db:seed:openvc`). The `openvc` npm package is unpublished;
# use a JSON file or your own `OPENVC_API_URL` proxy. See `data/openvc/investors.example.json`.
# OPENVC_JSON_PATH=
# OPENVC_API_URL=
# OPENVC_API_KEY=
# OPENVC_DEFAULT_FIRM_TYPE=ANGEL_NETWORK   # use VC for institutional firm lists
#
# Quick firm-only JSON (no people): write e.g. `{ "firms": ["Sequoia Capital", "Accel"] }` then:
#   OPENVC_JSON_PATH=./data/vc-250.json OPENVC_DEFAULT_FIRM_TYPE=VC npm run db:seed:openvc
#
# VC Sheet listing import (`npm run db:seed:vcsheet`). Fetches the public /investors HTML (~100 SSR rows).
# VCSHEET_FETCH_ONLY=1 — write `data/vcsheet/investors.json` only (no DB).
# VCSHEET_OFFLINE=1 — read `VCSHEET_JSON_PATH` instead of fetching.
# VCSHEET_SAVE_JSON=1 — also write JSON when importing to DB.
# VCSHEET_JSON_OUT= — override output path (default: data/vcsheet/investors.json)
# VCSHEET_DEFAULT_FIRM_TYPE=VC
#
# Employbl / GitHub venture-capital.csv (`npm run db:seed:venture-csv`)
# Default URL: https://raw.githubusercontent.com/connor11528/tech-companies-and-startups/master/venture-capital.csv
# VENTURE_CSV_PATH=          # local file overrides fetch
# VENTURE_CSV_URL=
# VENTURE_CSV_FETCH_ONLY=1
# VENTURE_CSV_JSON_OUT=
# VENTURE_CSV_FIRM_TYPE=VC
#
# Airtable VC table (`npm run db:seed:airtable`) — needs a Personal Access Token with base read access
# https://airtable.com/create/tokens
# AIRTABLE_TOKEN=pat...
# AIRTABLE_BASE_ID=appYlRDIZLwvRPsRh
# AIRTABLE_TABLE_ID=tbl5Q8N7NuW22z5Bt
# AIRTABLE_JSON_PATH=        # optional: { "records": [...] } export instead of live API
# AIRTABLE_FETCH_ONLY=1
# AIRTABLE_JSON_OUT=
# AIRTABLE_SOURCE_URL=       # stored on VCSourceLink for provenance
# AIRTABLE_DEFAULT_FIRM_TYPE=VC
#
# NFX Signal /investors HTML (`npm run db:seed:signal-nfx`) — Apollo cache in page; API needs login.
# Writes `data/imports/signal-nfx-lists.json` + `signal-nfx-featured.json`; DB import uses featured only.
# SIGNAL_NFX_FETCH_ONLY=1
# SIGNAL_NFX_HTML_PATH=       # saved HTML instead of fetch
# SIGNAL_NFX_LISTS_JSON=
# SIGNAL_NFX_FEATURED_JSON=
# SIGNAL_NFX_FIRM_TYPE=VC
#
# Startup professionals — idempotent merge (`npm run db:seed:all-professionals`)
# Run (after `npx prisma migrate deploy`): same commands are safe to re-run; rows merge by linkedin → angelListId → (fullName+currentStartup).
# PROFESSIONALS_AUDIT_LOG=0 — disable `startup_professional_changelogs` writes (default: on).
# PROFESSIONALS_MERGE_LOG_EVERY=250 — progress during merge (0 = no merge progress lines).
# PROFESSIONALS_MERGE_BY_NAME=1 — if exactly one row matches normalized fullName, treat as same person (use sparingly).
#
# YC (sourcePriority 100): https://www.ycombinator.com/companies/sitemap + /companies/{slug}
#   YC_PROFESSIONALS_JSON_PATH=./sample-data/yc-professionals.example.json
#   YC_COMPANIES_JSON_PATH=./path/to/companies-with-founders.json
#   YC_MAX_SLUGS=500  YC_REQUEST_MS_DELAY=150  YC_FETCH_CONCURRENCY=6
#   YC_FETCH_USER_AGENT=Mozilla/5.0 …  # optional; Node fetch may 404 — script falls back to curl unless YC_FETCH_DISABLE_CURL=1
#
# AngelList JSON only (60): ANGELLIST_FOUNDERS_JSON_PATH=./sample-data/angellist-founders.example.json
#
# Product Hunt GraphQL (80): PRODUCTHUNT_ACCESS_TOKEN=  # or PRODUCTHUNT_TOKEN — sample payload: sample-data/producthunt-professionals.example.json
# PH_MAX_PAGES=15  PH_POSTS_PER_PAGE=20
#
# GitHub Search users (70): GITHUB_TOKEN=  # optional PAT — sample payload: sample-data/github-professionals.example.json
# GITHUB_USER_SEARCH_QUERY=type:user followers:>3000
# GITHUB_SEARCH_MAX_PAGES=10  GITHUB_TOP_REPO_STARS=1
# GITHUB_SKIP_INVESTOR_HEURISTIC=0 — set to 0 to ingest bios that look like VCs (default: filter on)
#
# futureforumx/founder-s-ally GitHub CSVs (`npm run db:seed:founder-sally`)
# https://github.com/futureforumx/founder-s-ally
# FOUNDER_ALLY_FETCH_ONLY=1
# FOUNDER_ALLY_ONLY=nyc_early_stage,gigasheet,accelerators,firms_grid,investors_grid,early_stage_list
# FOUNDER_ALLY_MAX_ROWS=2000          # cap rows per file (Gigasheet is ~24k)
# FOUNDER_ALLY_CSV_PATH=            # single local file; optional FOUNDER_ALLY_PROFILE= + FOUNDER_ALLY_BLOB_NAME=
#
# Google Stitch MCP (Cursor `.cursor/mcp.json` → `stitch` server).
# Cursor resolves `${STITCH_GOOGLE_API_KEY}` from the environment of the Cursor app — not from Vite `.env.local`.
# Set it in your shell profile, or macOS `launchctl setenv`, or Cursor “env” if your build supports it, then restart Cursor.
# STITCH_GOOGLE_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Cloudflare R2 (S3-compatible) — headshots + logos (scripts + `/api/firm-website-team` mirror)
# Copy into `.env.local` for local dev; set the same keys on Vercel (all environments that hit the API).
# ─────────────────────────────────────────────────────────────────
# CF_R2_ACCESS_KEY_ID=
# CF_R2_SECRET_ACCESS_KEY=
# CF_R2_BUCKET_HEADSHOTS=
# CF_R2_PUBLIC_BASE_HEADSHOTS=   # public CDN base, no trailing slash (e.g. https://pub-xxxx.r2.dev)
# VITE_HEADSHOT_CDN_BASE=        # same URL as CF_R2_PUBLIC_BASE_HEADSHOTS — browser uses it to prefer R2 in avatar fallback order
# CF_R2_ENDPOINT=                # optional if you set CF_R2_ACCOUNT_ID instead
# CF_R2_ACCOUNT_ID=               # optional; default endpoint https://{id}.r2.cloudflarestorage.com
# CF_R2_BUCKET_LOGOS=            # used by logo enrichment scripts only
# CF_R2_PUBLIC_BASE_LOGOS=

# ─────────────────────────────────────────────────────────────────
# VC Enrichment Scraper (overnight multi-source backfill)
# npm run enrich:vc                      # production all sources
# npm run enrich:vc:dry                  # dry run all sources
# npm run enrich:vc:sample               # dry run 20-record sample
# npm run enrich:vc:tracxn               # Tracxn only
# npm run enrich:vc:cbi                  # CB Insights only
# npm run enrich:vc:signal               # Signal NFX only
# ENRICH_RESUME=<run-id> npm run enrich:vc   # resume from checkpoint
# ─────────────────────────────────────────────────────────────────

# Tracxn credentials (platform.tracxn.com)
# TRACXN_EMAIL=
# TRACXN_PASSWORD=
# TRACXN_HEADLESS=true
# TRACXN_DELAY_MS=2000
# TRACXN_AUTH_FILE=data/tracxn-auth.json

# CB Insights credentials (app.cbinsights.com) — also used by existing CB scraper
# CBI_EMAIL=
# CBI_PASSWORD=
# CBI_HEADLESS=true
# CBI_DELAY_MS=3000
# CBI_AUTH_FILE=data/cbi-auth.json

# Signal NFX credentials (signal.nfx.com) — also used by existing Signal scraper
# SIGNAL_NFX_EMAIL=
# SIGNAL_NFX_PASSWORD=
# SIGNAL_NFX_HEADLESS=true
# SIGNAL_NFX_DELAY_MS=1500
# SIGNAL_AUTH_FILE=data/signal-nfx-auth.json
# SIGNAL_NFX_PROXY=             # optional: http://user:pass@host:port

# Orchestrator controls
# ENRICH_DRY_RUN=1              # skip DB writes
# ENRICH_SOURCES=tracxn,cb_insights,signal_nfx
# ENRICH_MAX_FIRMS=999999
# ENRICH_MAX_INVESTORS=999999
# ENRICH_SAMPLE=20              # sample N records, implies dry run
# ENRICH_RESUME=                # resume from a run ID
# ENRICH_FIRM_FILTER=           # substring filter on firm name
# ENRICH_INVESTOR_FILTER=       # substring filter on investor name
